# BEACON control-plane — example environment (V0 skeleton)
# Copy to .env (gitignored) and adjust per-environment.

# --- service identity ------------------------------------------------------
BEACON_SERVICE_NAME=rewire-beacon
BEACON_ENVIRONMENT=dev
BEACON_LOG_LEVEL=INFO

# --- HTTP ------------------------------------------------------------------
BEACON_HTTP_HOST=0.0.0.0
BEACON_HTTP_PORT=8080

# --- persistence -----------------------------------------------------------
# V0 fallback: SQLite. V0.1+ default: Postgres CNPG cluster.
BEACON_DATABASE_URL=sqlite+aiosqlite:///./beacon.dev.db
BEACON_REDIS_URL=redis://localhost:6379/0
BEACON_RABBITMQ_URL=amqp://guest:guest@localhost:5672/%2F
BEACON_KAFKA_BROKERS=localhost:9092
BEACON_CLICKHOUSE_URL=http://localhost:8123

# --- identity / security ---------------------------------------------------
BEACON_VAULT_ADDR=http://vault.security.svc.cluster.local:8200
BEACON_OIDC_ISSUER=https://auth.rewirelabs.dev/application/o/beacon/
BEACON_OIDC_CLIENT_ID=beacon
BEACON_OIDC_CLIENT_SECRET=change-me

# --- cross-product ---------------------------------------------------------
BEACON_CONNECT_INTERNAL_BASE_URL=http://connect.connect.svc.cluster.local:8080
BEACON_CITADEL_CHAIN_BASE_URL=http://citadel.rewire-citadel.svc.cluster.local:8080
BEACON_AUDIT_TRAIL_BASE_URL=http://audit-trail.rewire-audit-trail.svc.cluster.local:8080

# --- channel providers (V0.2+) --------------------------------------------
BEACON_POSTAL_API_URL=http://postal.beacon.svc.cluster.local:5000
BEACON_POSTAL_API_KEY=
BEACON_SES_REGION=sa-east-1
BEACON_SES_ACCESS_KEY_ID=
BEACON_SES_SECRET_ACCESS_KEY=
BEACON_ZENVIA_API_TOKEN=
BEACON_TOTALVOICE_API_TOKEN=
BEACON_APNS_TEAM_ID=
BEACON_APNS_KEY_ID=
BEACON_FCM_SERVICE_ACCOUNT_JSON=
BEACON_VAPID_PUBLIC_KEY=
BEACON_VAPID_PRIVATE_KEY=

# --- observability ---------------------------------------------------------
BEACON_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
BEACON_OTEL_SERVICE_NAME=rewire-beacon
